{
  "name": "companybrain",
  "version": "0.1.0",
  "private": true,
  "description": "CompanyBrain — the open-source, self-hostable memory layer for your team. Index everything, recall anything.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/aayambansal/companybrain.git"
  },
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md,mjs}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md,mjs}\"",
    "clean": "turbo run clean && rm -rf node_modules",
    "db:generate": "pnpm --filter @companybrain/db generate",
    "db:migrate": "pnpm --filter @companybrain/db migrate",
    "db:push": "pnpm --filter @companybrain/db push",
    "db:studio": "pnpm --filter @companybrain/db studio",
    "db:seed": "pnpm --filter @companybrain/db seed"
  },
  "devDependencies": {
    "prettier": "^3.3.3",
    "turbo": "^2.1.3",
    "typescript": "^5.6.2"
  },
  "pnpm": {
    "neverBuiltDependencies": [
      "canvas",
      "isolated-vm"
    ]
  }
}
