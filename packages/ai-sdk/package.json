{
  "name": "@companybrain/ai-sdk",
  "version": "0.1.0",
  "description": "Vercel AI SDK tools for CompanyBrain — give any AI SDK agent memory it can search and write.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/aayambansal/companybrain.git",
    "directory": "packages/ai-sdk"
  },
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "files": [
    "dist",
    "src",
    "README.md"
  ],
  "keywords": [
    "companybrain",
    "vercel",
    "ai-sdk",
    "tools",
    "memory",
    "rag"
  ],
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "clean": "rm -rf dist .turbo *.tsbuildinfo"
  },
  "dependencies": {
    "@companybrain/sdk": "workspace:*",
    "zod": "^3.23.8"
  },
  "peerDependencies": {
    "ai": ">=5.0.0"
  },
  "devDependencies": {
    "ai": "^7.0.37",
    "@types/node": "^22.7.4",
    "typescript": "^5.6.2",
    "vitest": "^2.1.2"
  },
  "publishConfig": {
    "access": "public",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js"
      }
    }
  },
  "author": "aayambansal",
  "homepage": "https://github.com/aayambansal/companybrain#readme",
  "bugs": "https://github.com/aayambansal/companybrain/issues"
}
