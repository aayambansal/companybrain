  },
  "dependencies": {
    "@companybrain/sdk": "workspace:*"
  },
  "peerDependencies": {
    "@langchain/core": ">=0.3.0"
  },
  "devDependencies": {
    "@langchain/core": "^1.2.3",
    "@types/node": "^26.1.1",
    "typescript": "^7.0.2",
    "vitest": "^4.1.10"
  }
