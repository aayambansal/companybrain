{
  "name": "@companybrain/langchain",
  "version": "0.1.0",
  "description": "LangChain retriever for CompanyBrain — plug your company memory into any LangChain / LangGraph chain.",
  "license": "MIT",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "files": [
    "dist",
    "src",
    "README.md"
  ],
  "keywords": [
    "companybrain",
    "langchain",
    "retriever",
    "rag",
    "memory"
  ],
  "scripts": {
