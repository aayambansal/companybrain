{
  "name": "n8n-nodes-companybrain",
  "version": "0.1.0",
  "description": "n8n community node for CompanyBrain — search, add, and ask your company memory in any workflow.",
  "license": "MIT",
  "keywords": [
    "n8n-community-node-package",
    "companybrain",
    "memory",
    "rag"
  ],
  "type": "commonjs",
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist .turbo *.tsbuildinfo"
  },
  "n8n": {
    "n8nNodesApiVersion": 1,
    "credentials": [
      "dist/credentials/CompanyBrainApi.credentials.js"
    ],
    "nodes": [
      "dist/nodes/CompanyBrain/CompanyBrain.node.js"
    ]
  },
  "files": [
    "dist"
  ],
  "peerDependencies": {
    "n8n-workflow": "*"
  },
  "devDependencies": {
    "n8n-workflow": "^1.70.0",
    "@types/node": "^22.7.4",
    "typescript": "^5.6.2"
  }
}
