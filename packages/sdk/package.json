{
  "name": "@companybrain/sdk",
  "version": "0.1.0",
  "description": "Official TypeScript SDK for CompanyBrain, the open-source memory layer.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/aayambansal/companybrain.git",
    "directory": "packages/sdk"
  },
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "files": [
    "dist",
    "src",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist .turbo *.tsbuildinfo"
  },
  "keywords": [
    "companybrain",
    "memory",
    "rag",
    "vector",
    "search",
    "ai",
    "sdk"
  ],
  "devDependencies": {
    "@types/node": "^22.7.4",
    "typescript": "^5.6.2",
    "vitest": "^2.1.2"
  },
  "publishConfig": {
    "access": "public",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js"
      }
    }
  }
}
